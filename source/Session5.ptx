    <paragraphs>
        <title>Getting Warmed Up and in the Right Mindset</title>
    <exercise workspace="0.75in"> <!-- controlling workspace length is the best way to force page breaks on a worksheet -->
      <statement><!-- #1 -->
        <p>
            Let <m>f</m> and <m>g</m> be two differentiable functions.
            Circle the correct Product Rule for derivatives.
            <md>
            \text{Option 1:} \quad \frac{d}{dx}(f(x) \cdot g(x)) = \left(\frac{d}{dx}f(x)\right)\cdot\left(\frac{d}{dx}g(x)\right) 
            </md>
            <md>
            \text{Option 2:}\quad \frac{d}{dx}(f(x) \cdot g(x)) = f(x)\cdot\left(\frac{d}{dx}g(x)\right)+g(x)\cdot \left(\frac{d}{dx}f(x)\right)   
            </md>
            <md>
            \text{Option 3:}\quad frac{d}{dx}(f(x) \cdot g(x)) = f(x)\cdot\left(\frac{d}{dx}g(x)\right)\cdot g(x)\cdot \left(\frac{d}{dx}f(x)\right)   
            </md>       
        </p>
      </statement>
    </exercise>
